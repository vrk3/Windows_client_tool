{
  "name": "Corporate Hardened",
  "version": 1,
  "builtin": true,
  "description": "Telemetry off, remote registry off, delivery optimization off, hardened network settings.",
  "tweaks": {
    "telemetry": [
      "disable_diagtrack",
      "disable_utcsvc",
      "telemetry_zero",
      "disable_device_name_telemetry",
      "disable_telemetry_tasks",
      "disable_auto_logger",
      "disable_wersvc",
      "disable_mdm_enrollment"
    ],
    "services": [
      "disable_delivery_optimization",
      "disable_remote_registry",
      "disable_xbox_services",
      "disable_one_sync",
      "disable_windows_insider_service"
    ],
    "security": [
      "disable_remote_desktop",
      "disable_remote_assistance",
      "require_smb_signing",
      "require_ctrl_alt_del",
      "restrict_anonymous_access",
      "enable_firewall_all_profiles",
      "disable_smb1",
      "disable_llmnr",
      "enable_nla",
      "disable_admin_shares",
      "enable_smart_screen_filter",
      "secure_windows_defender"
    ],
    "network": [
      "disable_qos_reserved_bandwidth",
      "disable_netbios_tcpip",
      "disable_lmhosts_lookup",
      "disable_ipv6"
    ],
    "privacy": [
      "disable_peer_updates",
      "disable_cortana",
      "disable_windows_insider"
    ]
  },
  "apps": {"remove": [], "install": [], "protected": ["Microsoft.OneDriveSync"]}
}
