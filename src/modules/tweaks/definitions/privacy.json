      {"type":"script","command":"powershell -Command \"if (Test-Path '$env:windir\\System32\\WindowsCopilotLauncher.exe') { Rename-Item -Path '$env:windir\\System32\\WindowsCopilotLauncher.exe' -NewName 'WindowsCopilotLauncher.exe.bak' -Force }\"","revert_command":"powershell -Command \"if (Test-Path '$env:windir\\System32\\WindowsCopilotLauncher.exe.bak') { Rename-Item -Path '$env:windir\\System32\\WindowsCopilotLauncher.exe.bak' -NewName 'WindowsCopilotLauncher.exe' -Force }\""}
    ]
