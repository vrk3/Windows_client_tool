    "id": "win11_copilot_disable",
    "name": "Disable Windows Copilot",
    "description": "Disables the Windows Copilot (AI assistant) sidebar. On keyboards with a Copilot key, this prevents it from launching. Restart required.",
    "category": "Privacy", "risk": "low", "requires_admin": true,
