[
  {
    "id": "disable_diagtrack",
    "name": "Disable DiagTrack Service",
    "description": "Disables the Connected User Experiences and Telemetry service.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [{"type":"service","name":"DiagTrack","start_type":"disabled"}]
  },
  {
    "id": "disable_utcsvc",
    "name": "Disable UTC Service",
    "description": "Disables the Universal Telemetry Client service.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [{"type":"service","name":"utcsvc","start_type":"disabled"}]
  },
  {
    "id": "telemetry_zero",
    "name": "Set Telemetry Level to 0 (Security only)",
    "description": "Restricts Windows telemetry to the minimum — only critical security data. Enterprise feature; on Home this sets level 1.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection","value":"AllowTelemetry","data":0,"kind":"DWORD"},
      {"type":"registry","key":"HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\DataCollection","value":"AllowTelemetry","data":0,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_device_name_telemetry",
    "name": "Disable Device Name in Telemetry",
    "description": "Prevents sending the computer's name with telemetry data.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection","value":"AllowDeviceNameInTelemetry","data":0,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_wersvc",
    "name": "Disable Windows Error Reporting",
    "description": "Stops Windows from sending crash reports to Microsoft.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [{"type":"service","name":"WerSvc","start_type":"disabled"}]
  },
  {
    "id": "disable_ceip",
    "name": "Disable Customer Experience Improvement Program",
    "description": "Disables CEIP scheduled tasks that collect usage statistics.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"command","cmd":"schtasks /change /tn \"\\Microsoft\\Windows\\Customer Experience Improvement Program\\Consolidator\" /disable"},
      {"type":"command","cmd":"schtasks /change /tn \"\\Microsoft\\Windows\\Customer Experience Improvement Program\\UsbCeip\" /disable"}
    ]
  },
  {
    "id": "disable_inventory_collector",
    "name": "Disable Application Compatibility Telemetry",
    "description": "Disables the app compatibility appraiser scheduled task that collects installed software data.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"command","cmd":"schtasks /change /tn \"\\Microsoft\\Windows\\Application Experience\\Microsoft Compatibility Appraiser\" /disable"}
    ]
  },
  {
    "id": "disable_feedback_requests",
    "name": "Disable Feedback Requests",
    "description": "Stops Windows from asking for periodic feedback and satisfaction surveys.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection","value":"DoNotShowFeedbackNotifications","data":1,"kind":"DWORD"},
      {"type":"registry","key":"HKCU\\SOFTWARE\\Microsoft\\Siuf\\Rules","value":"NumberOfSIUFInPeriod","data":0,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_consumer_features",
    "name": "Disable Microsoft Consumer Features",
    "description": "Prevents Windows from automatically installing promoted and sponsored apps.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\CloudContent","value":"DisableWindowsConsumerFeatures","data":1,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_spynet",
    "name": "Disable Defender SpyNet / MAPS Reporting",
    "description": "Stops Windows Defender from submitting file samples to Microsoft's cloud. Medium risk — reduces cloud-based threat detection.",
    "category": "Telemetry", "risk": "medium", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Spynet","value":"SpynetReporting","data":0,"kind":"DWORD"},
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Spynet","value":"SubmitSamplesConsent","data":2,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_maps_autoupdate",
    "name": "Disable Maps Auto-Download",
    "description": "Prevents Windows Maps from automatically downloading map data in the background.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\Maps","value":"AutoDownloadAndUpdateMapData","data":0,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_mdm_enrollment",
    "name": "Disable Automatic MDM Enrollment",
    "description": "Prevents Windows from automatically enrolling in Mobile Device Management (corporate device management).",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\CurrentVersion\\MDM","value":"DisableRegistration","data":1,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_diag_track_blocking",
    "name": "Block DiagTrack Service (Block Task)",
    "description": "Blocks the DiagTrack service from running at all by setting it to a blocked task. Stronger than just setting start_type=disabled.",
    "category": "Telemetry", "risk": "medium", "requires_admin": true,
    "steps": [
      {"type":"service","name":"DiagTrack","start_type":"disabled"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Application Experience\\AitAgent\" /disable"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Application Experience\\ProgramDataUpdater\" /disable"}
    ]
  },
  {
    "id": "disable_auto_logger",
    "name": "Disable Windows AutoLogger",
    "description": "Disables the Windows AutoLogger that continuously writes telemetry to disk. Reduces write I/O and telemetry data collection.",
    "category": "Telemetry", "risk": "medium", "requires_admin": true,
    "steps": [
      {"type":"command","cmd":"powershell -Command \"$acl = Get-Acl 'HKLM:\\SYSTEM\\CurrentControlSet\\Control\\WMI\\AutoLogger'; $rule = New-Object System.Security.AccessControl.RegistryAuditRule('Everyone','FullControl','None','None','Deny'); $acl.AddAuditRule($rule); Set-Acl -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Control\\WMI\\AutoLogger' -AclObject $acl\""}
    ]
  },
  {
    "id": "disable_telemetry_tasks",
    "name": "Disable All Telemetry Scheduled Tasks",
    "description": "Disables the collection of telemetry via all Microsoft telemetry scheduled tasks across Application Experience, Customer Experience Improvement, and Windows Insider.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Application Experience\\AitAgent\" /disable 2>nul"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Application Experience\\ProgramDataUpdater\" /disable 2>nul"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Customer Experience Improvement Program\\Consolidator\" /disable 2>nul"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Customer Experience Improvement Program\\UsbCeip\" /disable 2>nul"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Application Experience\\Microsoft Compatibility Appraiser\" /disable 2>nul"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\DiskDiagnostic\\Microsoft-Windows-DiskDiagnosticDataCollector\" /disable 2>nul"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Feedback\\Siuf\\DmClient\" /disable 2>nul"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Feedback\\Siuf\\DmClientOnScenarioDownload\" /disable 2>nul"},
      {"type":"command","cmd":"schtasks /change /tn \"Microsoft\\Windows\\Windows Error Reporting\\QueueReporting\" /disable 2>nul"}
    ]
  },
  {
    "id": "disable_office_telemetry",
    "name": "Disable Office Telemetry",
    "description": "Disables the Office telemetry agent that logs document and add-in usage to Microsoft 365. Safe for personal and corporate environments without Office telemetry requirements.",
    "category": "Telemetry", "risk": "low", "requires_admin": false,
    "steps": [
      {"type":"registry","key":"HKCU\\SOFTWARE\\Microsoft\\Office\\16.0\\Common","value":"SendCustomerData","data":0,"kind":"DWORD"},
      {"type":"registry","key":"HKCU\\SOFTWARE\\Microsoft\\Office\\16.0\\Common\\Feedback","value":" QuestionnaireEnabled","data":0,"kind":"DWORD"},
      {"type":"registry","key":"HKCU\\SOFTWARE\\Microsoft\\Office\\16.0\\Common\\Feedback","value":"AutomaticSending","data":0,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_edge_telemetry",
    "name": "Disable Microsoft Edge Telemetry",
    "description": "Disables Microsoft Edge browsing telemetry and personalised ad tracking via the UI. Does not affect Edge's security features.",
    "category": "Telemetry", "risk": "low", "requires_admin": false,
    "steps": [
      {"type":"registry","key":"HKCU\\SOFTWARE\\Classes\\Local Settings\\Software\\Microsoft\\Windows\\CurrentVersion\\AppContainer\\Storage\\Microsoft.MicrosoftEdge\\Main","value":"CookiesAreBlocked","data":1,"kind":"DWORD"},
      {"type":"registry","key":"HKCU\\SOFTWARE\\Microsoft\\Edge\\Main","value":"PersonalizationAdvertisingEnabled","data":0,"kind":"DWORD"},
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Edge","value":"EdgePrivacyAdvertisingEnabled","data":0,"kind":"DWORD"},
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Edge","value":"EdgeSendSiteInfoToSend","data":0,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_windows_security_telemetry",
    "name": "Disable Windows Security Centre Telemetry",
    "description": "Stops Windows Security health reports from being sent to Microsoft. The Security dashboard still works locally.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Reporting","value":"DisableGenericReports","data":1,"kind":"DWORD"},
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\SmartScreen","value":"ConfigureTelemetryReporting","data":0,"kind":"DWORD"}
    ]
  },
  {
    "id": "disable_winsetup_telemetry",
    "name": "Disable Setup Telemetry",
    "description": "Disables the Windows Setup Exploit Guard telemetry that is sent after feature updates.",
    "category": "Telemetry", "risk": "low", "requires_admin": true,
    "steps": [
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\WindowsSetup","value":"DisableTelemetry","data":1,"kind":"DWORD"},
      {"type":"registry","key":"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\WindowsUpdate\\OSUpgrade","value":"AllowTelemetry","data":0,"kind":"DWORD"}
    ]
  }
]
