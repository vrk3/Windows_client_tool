      {"type":"command","cmd":"powershell -Command \"$sh='{20D04FE0-3AEA-1069-A2D8-08002B30309D}'; $desktop='::{20D04FE0-3AEA-1069-A2D8-08002B30309D}'; $exist=Get-ChildItem 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Desktop\\NameSpace\\{20D04FE0-3AEA-1069-A2D8-08002B30309D}' -ErrorAction SilentlyContinue; if(-not$exist){New-Item -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Desktop\\NameSpace\\{20D04FE0-3AEA-1069-A2D8-08002B30309D}' -Force | Out-Null}\""}
    ]
  },
